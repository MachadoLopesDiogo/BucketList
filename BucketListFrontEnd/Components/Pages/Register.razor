@page "/register"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

    <div class="mb-3 mt-3">
    <label for="username">Gebruikersnaam:</label>
    <input type="text" class="form-control" id="username" placeholder="gebruikersnaam" @bind="_usernameRegister" />
    </div>

<div class="mb-3">
    <label for="password">Wachtwoord:</label>
    <input type="password" class="form-control" id="password" placeholder="wachtwoord" @bind="_passwordRegister" />
</div>

<button class="btn btn-primary" @onclick="LoginUser">Log in</button>
@code{
    private string _usernameRegister = "";
    private string _passwordRegister = "";

    private async Task LoginUser()
    {
        var url = $"/users/login?username={Uri.EscapeDataString(_usernameRegister)}&password={Uri.EscapeDataString(_passwordRegister)}";
        var response = await Http.GetAsync(url);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/bucketlistitem");
        }
        
        
    
        

    }
}
